# Google Cloud OAuth credentials — Console → APIs & Services → Credentials →
# Create OAuth client ID (type: Desktop app). Then, under "OAuth consent screen",
# PUBLISH the app to production — apps left in Testing status get refresh tokens
# that expire every 7 days, which silently kills the data sync.
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Friendly name for your tracker, tagged on every data point.
DEVICENAME=Fitbit_Air

# Drives the Fitness Age score (Nes 2011 model — sex-specific coefficients).
USER_AGE=30
USER_SEX=male

# IANA timezone for the body-clock (circadian) analysis — local hours matter.
LOCAL_TZ=Europe/Madrid
